# ── Base de datos ─────────────────────────────────────────────────
# URL completa de PostgreSQL en Neon
# Formato: postgresql://usuario:password@host/dbname?sslmode=require
DATABASE_URL=

# ── JWT ───────────────────────────────────────────────────────────
# Clave secreta para firmar tokens. Generar con:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# Algoritmo de firma JWT
ALGORITHM=HS256

# Tiempo de vida del token en minutos (60 * 24 * 7 = 1 semana)
ACCESS_TOKEN_EXPIRE_MINUTES=10080
