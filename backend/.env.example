# ── Base de datos ─────────────────────────────────────────────────
# URL completa de PostgreSQL en Neon
# Formato: postgresql://usuario:password@host/dbname?sslmode=require
DATABASE_URL=

# ── JWT ───────────────────────────────────────────────────────────
# Clave secreta para firmar tokens. Generar con:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# Algoritmo de firma JWT
ALGORITHM=HS256

# Tiempo de vida del token en minutos (60 * 24 * 7 = 1 semana)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Gemini AI ─────────────────────────────────────────────────────
# API key de Google AI Studio: https://aistudio.google.com/apikey
# El sistema funciona sin esta key (cae al motor de reglas), pero la
# experiencia es mucho mejor con IA activada.
GEMINI_API_KEY=

# Modelo a usar. Por defecto gemini-2.5-flash (free tier, rápido).
# Otras opciones: gemini-2.5-flash-lite (más barato), gemini-2.5-pro (mejor calidad).
GEMINI_MODEL=gemini-2.5-flash
